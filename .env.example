# ── Pick ONE provider ────────────────────────────────────────────────────────
# Copy this file to .env:  cp .env.example .env
# With NO keys set, the app runs in "offline demo" mode (works, but placeholder
# content). Add ONE free key below for real generation.

# 1) FREE & recommended — Groq (fast). Get a free key (no card):
#    https://console.groq.com/keys
# GROQ_API_KEY=gsk_...

# 2) FREE — Google Gemini (great for Georgian). Get a free key:
#    https://aistudio.google.com/apikey
# GEMINI_API_KEY=...

# 3) Claude (best quality + live web search; paid). Needs account credits:
#    https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides ───────────────────────────────────────────────────────
# Force a provider regardless of which keys are set: groq | gemini | anthropic | offline
# LLM_PROVIDER=groq
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.0-flash
# ANTHROPIC_MODEL=claude-opus-4-8
